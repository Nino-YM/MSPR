{
  "title": "EDF Prediction API",
  "uid": "edf-prediction-api",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Modèles chargés",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "edf_models_loaded",
          "legendFormat": "Modèles",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Prédictions totales",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(edf_predictions_total)",
          "legendFormat": "Total",
          "datasource": "Prometheus"
        }
      ],
      "options": { "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Taux d'erreur",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(edf_predictions_total{status=\"error\"}[5m])) / sum(rate(edf_predictions_total[5m])) * 100",
          "legendFormat": "% erreurs",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "unit": "percent",
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 5 },
            { "color": "red", "value": 10 }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Latence P95 (toutes requêtes)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(edf_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "unit": "s",
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 0.5 },
            { "color": "red", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "MAPE par modèle (%)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "edf_model_mape_pct",
          "legendFormat": "{{model}}",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "unit": "percent",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 10 },
            { "color": "red", "value": 20 }
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Prédictions par modèle (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(edf_predictions_total{status=\"success\"}[1m])) by (model) * 60",
          "legendFormat": "{{model}}",
          "datasource": "Prometheus"
        }
      ],
      "options": { "unit": "reqps" }
    },
    {
      "id": 7,
      "title": "Latence par modèle (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(edf_prediction_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "P50 {{model}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(edf_prediction_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "P95 {{model}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(edf_prediction_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "P99 {{model}}",
          "datasource": "Prometheus"
        }
      ],
      "options": { "unit": "s" }
    },
    {
      "id": 8,
      "title": "Erreurs par modèle (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(edf_predictions_total{status=\"error\"}[1m])) by (model) * 60",
          "legendFormat": "{{model}}",
          "datasource": "Prometheus"
        }
      ],
      "options": { "unit": "reqps" }
    },
    {
      "id": 9,
      "title": "Uptime Prometheus",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"edf-api\"}",
          "legendFormat": "Uptime API",
          "datasource": "Prometheus"
        }
      ],
      "options": { "unit": "s" }
    },
    {
      "id": 10,
      "title": "Mémoire API (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"edf-api\"} / 1024 / 1024",
          "legendFormat": "RSS (MB)",
          "datasource": "Prometheus"
        }
      ],
      "options": { "unit": "MB" }
    }
  ]
}
